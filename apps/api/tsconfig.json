{
    "compilerOptions": {
        "ignoreDeprecations": "5.0",
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "rootDir": "src"
    },
    "references": [{ "path": "../../packages/shared" }],
    "include": ["src"]
}
